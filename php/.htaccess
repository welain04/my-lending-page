RewriteEngine On

# HTTP → HTTPS (SpaceWeb: nginx отдаёт X-Forwarded-Proto)
SetEnvIf X-Forwarded-Proto https SERVER_PORT=443
SetEnvIf X-Forwarded-Proto https HTTPS=on
RewriteCond %{HTTP:HTTPS} !=on [NC]
RewriteRule ^(.*)$ https://%{SERVER_NAME}%{REQUEST_URI} [R=301,L]

# Красивый путь /api/lead → api/lead.php (фронтенд шлёт на /api/lead)
RewriteRule ^api/lead/?$ api/lead.php [L]

# Секреты формы недоступны напрямую из браузера (Apache 2.2)
<Files "config.php">
  Order allow,deny
  Deny from all
</Files>

# Кэш статичных ассетов Astro (имена с хэшем — можно кэшировать надолго)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
</IfModule>
