---
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-ink">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-5 py-8 text-sm text-muted md:flex-row">
    <div class="flex items-center gap-2 font-semibold text-text">
      <span class="flex h-7 w-7 items-center justify-center rounded-md brand-solid text-xs font-bold">V</span>
      vibestudio
    </div>
    <p>© {year} · Сайты, боты и AI-помощники на вайбкодинге</p>
    <button data-open-lead class="font-semibold transition brand-emerald hover:text-brand-strong">
      Написать →
    </button>
  </div>
</footer>
