---
const faqs = [
  {
    q: "Я не разбираюсь в технике — справлюсь?",
    a: "Да. Вся настройка на мне. Вы получаете готовое и просто пользуетесь.",
  },
  {
    q: "Чем вайбкодинг отличается от агентства?",
    a: "Тот же результат, но в разы быстрее и дешевле — потому что без раздутой команды и месяцев согласований.",
  },
  {
    q: "А если результат не понравится?",
    a: "Согласуем смысл и структуру до старта, дорабатываю по вашим правкам. Вы видите первую версию быстро и влияете на неё.",
  },
  {
    q: "AI-помощник не наговорит клиентам лишнего?",
    a: "Он работает строго по вашей базе знаний и правилам — не выдумывает, а отвечает так, как ответили бы вы.",
  },
  {
    q: "Сколько ждать запуск?",
    a: "Обычно несколько дней, а не месяцы. Точный срок скажу на разборе.",
  },
  {
    q: "Есть поддержка после запуска?",
    a: "Да, остаюсь на связи и помогаю с доработками.",
  },
];
---

<section id="faq" class="border-b border-line">
  <div class="mx-auto max-w-3xl px-5 py-16 md:py-24">
    <h2 class="text-center text-3xl font-bold tracking-tight md:text-4xl">
      Частые вопросы
    </h2>

    <div class="mt-10 space-y-3">
      {
        faqs.map((item) => (
          <details class="group rounded-xl border border-line bg-card p-5 [&_svg]:open:rotate-45">
            <summary class="flex cursor-pointer items-center justify-between gap-4 font-semibold">
              {item.q}
              <svg
                class="h-5 w-5 shrink-0 text-muted transition-transform"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              >
                <path d="M12 5v14M5 12h14" />
              </svg>
            </summary>
            <p class="mt-3 leading-relaxed text-muted">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
