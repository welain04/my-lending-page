---
const items = [
  {
    title: "Лендинг, который продаёт",
    text: "Клиент за 5 секунд понимает, зачем вы ему, и оставляет заявку — а не уходит к конкуренту.",
    icon: `<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 21h8"/>`,
  },
  {
    title: "Telegram-бот для записи и рутины",
    text: "Сам записывает, отвечает на частые вопросы и напоминает клиентам — 24/7, без вашего участия.",
    icon: `<path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.5 8.5 0 1 1 21 11.5z"/>`,
  },
  {
    title: "AI-помощник с вашей базой знаний",
    text: "Карманный эксперт, который отвечает клиентам по вашим правилам и вашим ценам, будто это вы сами.",
    icon: `<path d="M12 3l1.9 4.6L18.5 9l-4.6 1.9L12 15.5l-1.9-4.6L5.5 9l4.6-1.4z"/><path d="M18 15l.8 2 2 .8-2 .8-.8 2-.8-2-2-.8 2-.8z"/>`,
  },
  {
    title: "Вайбкодинг вместо агентства",
    text: "Запуск за дни и по цене, посильной малому бизнесу, а не за месяцы и сотни тысяч.",
    icon: `<path d="M13 2L3 14h7l-1 8 10-12h-7z"/>`,
  },
];
---

<section id="solution" class="border-b border-line">
  <div class="mx-auto max-w-6xl px-5 py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        Три инструмента, которые работают за вас
      </h2>
      <p class="mt-4 text-lg text-muted">
        Не набор технологий, а конкретная выгода для вашего бизнеса.
      </p>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-2">
      {
        items.map((it) => (
          <div class="rounded-2xl border border-line bg-card p-6 transition hover:border-accent/50">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-brand-soft brand-emerald">
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={it.icon}
              />
            </div>
            <h3 class="text-xl font-semibold">{it.title}</h3>
            <p class="mt-2 leading-relaxed text-muted">{it.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
