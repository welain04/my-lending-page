---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Сайты, Telegram-боты и AI-помощники для бизнеса",
  description = "Собираю на вайбкодинге лендинги, Telegram-ботов для записи и AI-помощников с вашей базой знаний. Быстрее и дешевле агентства — запуск за считанные дни.",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <slot />
  </body>
</html>
