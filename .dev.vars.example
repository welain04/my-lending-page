# Скопируйте в .dev.vars для локального запуска функций через `wrangler pages dev`.
# В проде эти значения задаются в Cloudflare Pages → Settings → Environment variables.

TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Необязательно — запись заявок в Google-таблицу (см. google-apps-script.gs)
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
GOOGLE_SHEET_TOKEN=длинная_секретная_строка
